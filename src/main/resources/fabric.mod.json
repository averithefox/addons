{
  "schemaVersion": 1,
  "id": "foxaddons",
  "version": "${version}",
  "name": "Fox Addons",
  "description": "I'm gay",
  "authors": [
    "averithefox"
  ],
  "contact": {
    "homepage": "https://averi.me",
    "sources": "https://github.com/averithefox/addons"
  },
  "license": "GPL-3.0-or-later",
  "icon": "assets/foxaddons/icon.png",
  "environment": "client",
  "entrypoints": {
    "client": [
      {
        "value": "me.averi.wynntils.FoxAddons",
        "adapter": "kotlin"
      }
    ]
  },
  "mixins": [
    "foxaddons.mixins.json"
  ],
  "accessWidener": "foxaddons.accesswidener",
  "depends": {
    "fabricloader": ">=${loaderVersion}",
    "minecraft": "~${minecraftVersion}",
    "java": ">=21",
    "fabric-api": "*",
    "fabric-language-kotlin": "*",
    "wynntils": "~${wynntilsVersion}"
  }
}
